# Required — get from https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# Required — MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Flashmind

# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Optional — comma-separated list of allowed CORS origins (defaults to localhost:8000)
# CORS_ORIGINS=https://your-app.onrender.com

# Optional — set to "production" on Render to enable secure cookies
# ENV=production

# Optional — set to "true" on Render free tier to skip ChromaDB (saves ~200MB RAM)
# DISABLE_VECTOR_STORE=true
